"""Tests for the todo service (async, real in-memory SQLite)."""

from collections.abc import AsyncIterator

import pytest
from sqlalchemy.ext.asyncio import AsyncSession, async_sessionmaker, create_async_engine

from pyfly.data.relational.sqlalchemy import Base

from {{ package_name }}.models.todo import TodoCreate, TodoEntity
from {{ package_name }}.repositories.todo_repository import TodoRepository
from {{ package_name }}.services.todo_service import TodoService


@pytest.fixture
async def session() -> AsyncIterator[AsyncSession]:
    engine = create_async_engine("sqlite+aiosqlite:///:memory:")
    async with engine.begin() as conn:
        await conn.run_sync(Base.metadata.create_all)
    factory = async_sessionmaker(engine, expire_on_commit=False)
    async with factory() as db:
        yield db
    await engine.dispose()


@pytest.fixture
def service(session: AsyncSession) -> TodoService:
    return TodoService(TodoRepository(TodoEntity, session))


class TestTodoService:
    async def test_create_todo(self, service: TodoService) -> None:
        todo = await service.create(TodoCreate(title="Buy groceries", description="Milk and eggs"))
        assert todo.title == "Buy groceries"
        assert todo.completed is False
        assert todo.id

    async def test_list_todos(self, service: TodoService) -> None:
        await service.create(TodoCreate(title="Task A"))
        await service.create(TodoCreate(title="Task B"))
        assert len(await service.list_all()) == 2

    async def test_get_todo(self, service: TodoService) -> None:
        created = await service.create(TodoCreate(title="Buy groceries"))
        found = await service.get(created.id)
        assert found.title == "Buy groceries"

    async def test_toggle_complete(self, service: TodoService) -> None:
        created = await service.create(TodoCreate(title="Buy groceries"))
        assert created.completed is False
        toggled = await service.toggle_complete(created.id)
        assert toggled.completed is True

    async def test_delete_todo(self, service: TodoService) -> None:
        created = await service.create(TodoCreate(title="Buy groceries"))
        await service.delete(created.id)
        assert len(await service.list_all()) == 0
