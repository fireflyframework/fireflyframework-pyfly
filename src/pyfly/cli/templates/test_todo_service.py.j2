"""Tests for the todo service (async; fast unit tests with a mocked repository).

These need no running MongoDB: the repository is an ``AsyncMock`` and document
construction is stubbed. For a full integration test, install ``mongomock-motor``
(or use a real Mongo), call ``init_beanie(...)`` with ``TodoDocument``, and drive
``TodoDocumentRepository`` directly.
"""

from types import SimpleNamespace
from unittest.mock import AsyncMock

import pytest

import {{ package_name }}.services.todo_service as todo_service
from {{ package_name }}.models.todo import TodoCreate
from {{ package_name }}.services.todo_service import TodoService


def _doc(title: str, description: str = "", *, completed: bool = False) -> SimpleNamespace:
    return SimpleNamespace(id="65f0c0ffee1234567890abcd", title=title, description=description, completed=completed)


@pytest.fixture
def repository() -> AsyncMock:
    return AsyncMock()


@pytest.fixture
def service(repository: AsyncMock, monkeypatch: pytest.MonkeyPatch) -> TodoService:
    # Stub document construction so the service builds a plain object instead of a
    # Beanie document — no Beanie initialisation / MongoDB needed for these unit tests.
    monkeypatch.setattr(todo_service, "TodoDocument", lambda **kw: SimpleNamespace(id=None, **kw))
    return TodoService(repository)


class TestTodoService:
    async def test_create_todo(self, service: TodoService, repository: AsyncMock) -> None:
        repository.save.return_value = _doc("Buy groceries", "Milk and eggs")
        todo = await service.create(TodoCreate(title="Buy groceries", description="Milk and eggs"))
        assert todo.title == "Buy groceries"
        assert todo.completed is False
        assert todo.id
        repository.save.assert_awaited_once()

    async def test_list_todos(self, service: TodoService, repository: AsyncMock) -> None:
        repository.find_all.return_value = [_doc("Task A"), _doc("Task B")]
        assert len(await service.list_all()) == 2

    async def test_get_todo(self, service: TodoService, repository: AsyncMock) -> None:
        repository.find_by_id.return_value = _doc("Buy groceries")
        found = await service.get("65f0c0ffee1234567890abcd")
        assert found.title == "Buy groceries"

    async def test_toggle_complete(self, service: TodoService, repository: AsyncMock) -> None:
        repository.find_by_id.return_value = _doc("Buy groceries", completed=False)
        repository.save.return_value = _doc("Buy groceries", completed=True)
        toggled = await service.toggle_complete("65f0c0ffee1234567890abcd")
        assert toggled.completed is True

    async def test_delete_todo(self, service: TodoService, repository: AsyncMock) -> None:
        await service.delete("65f0c0ffee1234567890abcd")
        repository.delete.assert_awaited_once()
