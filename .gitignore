.DS_Store
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/
.env
*.db
.worktrees/
.idea/
docs/plans/

# Playwright MCP verification artifacts
.playwright-mcp/
.audit/

# Superpowers brainstorming visual companion scratch (local only)
.superpowers/

# GitHub Pages site build output (assembled by scripts/build_site.py)
/_site/
/site/

# The book's build sources are real source, not the Python build/ artifact dir
!book/build/
!book/build/**
book/build/**/__pycache__/

# Internal Claude / superpowers design docs + session files — kept local, never committed
.claude/
docs/superpowers/

# Ship the built book (the deliverable); the rest of book/dist/ stays ignored
!book/dist/
book/dist/**
!book/dist/pyfly-by-example.pdf
!book/dist/pyfly-by-example.epub
!book/dist/pyfly-by-example-es.pdf
!book/dist/pyfly-by-example-es.epub
